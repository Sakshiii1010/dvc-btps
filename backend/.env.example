# ─── DVC BTPS Backend Environment ────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/dvc_btps
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/dvc_btps
MONGO_URI=mongodb://localhost:27017/dvc_btps

# JWT secret — change this to a long random string in production
JWT_SECRET_KEY=dvc-btps-super-secret-key-change-in-production-2024

# ─── Twilio SMS Configuration ─────────────────────────────────────────────────
# Sign up FREE at: https://www.twilio.com/try-twilio
# After signup → Console Dashboard shows Account SID and Auth Token
# Buy/use a free trial number as TWILIO_FROM_NUMBER
#
# If you leave these blank/placeholder, the app will still work — SMS will be
# skipped gracefully with a console log. No crash.

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
